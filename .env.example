# Watson agent configuration
WATSON_AGENT=hermes           # hermes | direct | openclaw
HERMES_API_URL=http://localhost:8778

# Direct LLM (if WATSON_AGENT=direct)
DEEPSEEK_API_KEY=your_key_here
WATSON_MODEL=deepseek-chat

# GitHub OAuth (for free tier login)
# Get these at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# MCP Server (community knowledge graph)
MCP_PORT=8001
MCP_PUBLISH_ENABLED=true       # free tier: publish cases to community

# Web UI
WEB_PORT=8000
